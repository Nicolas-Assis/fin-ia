# ---- OpenRouter (Llama 4 Maverick) ----
OPENROUTER_API_KEY=sk-or-...
# opcional: modelo, caso queira trocar
LLM_MODEL=meta-llama/llama-4-maverick

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=123456:ABC...          # do @BotFather
TELEGRAM_CHAT_ID=000000000                # SEU chat id = DONO/admin (autoriza os outros com /convidar)
TELEGRAM_WEBHOOK_SECRET=uma-string-aleatoria-forte
# Chave "global" do Atalho = a chave do DONO (compatibilidade).
# Cada pessoa tem a PRÓPRIA chave, obtida com /atalho no bot.
SHORTCUT_API_KEY=outra-string-aleatoria-forte

# ---- Neon Postgres ----
# URL COM pooler (para as functions):
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require
# URL direta (para migrations):
DIRECT_URL=postgresql://user:pass@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# ---- App ----
APP_URL=https://seu-app.vercel.app        # set-webhook + link do relatório HTML
# opcional: link iCloud do atalho pronto do iOS (no app Atalhos: Compartilhar > Copiar link do iCloud).
# Se definido, o comando /atalho mostra um botão "📲 Instalar o atalho no iPhone".
SHORTCUT_TEMPLATE_URL=https://www.icloud.com/shortcuts/xxxxxxxx
